GEMINI_API_KEY=your-key-here

# Optional — Postgres audit store. If unset, DB writes are silently skipped.
# Example (Homebrew local): postgresql://localhost/marketpulse
# Example (Docker):         postgresql://postgres:postgres@localhost:5432/marketpulse
DATABASE_URL=

# Optional — Langfuse observability (https://langfuse.com, free tier available).
# If unset, all @observe() decorators are transparent no-ops.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional — NewsAPI (https://newsapi.org, free tier: 100 req/day).
NEWS_API_KEY=
