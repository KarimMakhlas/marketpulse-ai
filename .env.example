GEMINI_API_KEY=your-key-here

# Optional — Postgres audit store. If unset, DB writes are silently skipped.
# Example (Homebrew local): postgresql://localhost/marketpulse
# Example (Docker):         postgresql://postgres:postgres@localhost:5432/marketpulse
DATABASE_URL=

# Optional — Langfuse observability (https://langfuse.com, free tier available).
# If unset, all @observe() decorators are transparent no-ops.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional — NewsAPI (https://newsapi.org, free tier: 100 req/day).
NEWS_API_KEY=

# --- v0.4 API ---

# JWT signing secret. REQUIRED for the API in production — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# If unset, an ephemeral per-process key is used (tokens die on restart).
JWT_SECRET_KEY=
# Access-token lifetime in minutes (default 60).
JWT_EXPIRE_MINUTES=60

# Optional — Redis URL for distributed rate limiting. If unset, slowapi uses an
# in-process memory store (fine for a single API instance).
REDIS_URL=

# API bind address/port (defaults shown). 0.0.0.0 is correct inside containers.
API_HOST=0.0.0.0
API_PORT=8000
